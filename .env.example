# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string (production)
# Ensure the user has proper permissions and the database exists
DATABASE_URL=postgresql://user:password@localhost:5432/house_of_travel_db

# ============================================
# APPLICATION CONFIGURATION
# ============================================
VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001
NODE_ENV=development

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT Secret (use strong, unique string in production)
JWT_SECRET=your-very-secret-key-change-in-production-min-32-chars
JWT_EXPIRY=24h

# Refresh Token Secret
REFRESH_TOKEN_SECRET=your-refresh-secret-key-change-in-production
REFRESH_TOKEN_EXPIRY=7d

# ============================================
# EMAIL SERVICE (Gmail, SendGrid, etc.)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@houseoftravel.com
SMTP_FROM_NAME=House of Travel

# ============================================
# PAYMENT GATEWAY (Stripe)
# ============================================
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# FILE STORAGE (AWS S3)
# ============================================
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=house-of-travel-bucket
AWS_S3_REGION=us-east-1
AWS_S3_URL=https://house-of-travel-bucket.s3.us-east-1.amazonaws.com

# ============================================
# ADMIN CONFIGURATION
# ============================================
ADMIN_EMAIL=admin@houseoftravel.com
ADMIN_DEFAULT_PASSWORD=ChangeMe123!

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
SENTRY_DSN=

# ============================================
# FEATURE FLAGS (Optional)
# ============================================
ENABLE_OAUTH_GOOGLE=false
ENABLE_OAUTH_FACEBOOK=false
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=100
